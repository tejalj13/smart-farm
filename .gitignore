# AWS Elastic Beanstalk
# =========================
# Ignore all AWS EB logs and local states
.elasticbeanstalk/*
# CRITICAL: Allow the EB config file so GitHub Actions knows your Application Name
!.elasticbeanstalk/config.yml
!.elasticbeanstalk/*.global.yml
 
